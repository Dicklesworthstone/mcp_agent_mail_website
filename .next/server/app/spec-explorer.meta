{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/spec-explorer/layout,_N_T_/spec-explorer/page,_N_T_/spec-explorer"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/spec-explorer/__PAGE__",
    "/spec-explorer",
    "/_index",
    "/_head"
  ]
}